# Copy to server/.env and fill in. Never commit .env.
# Every variable here is parsed once, by zod, in src/config/env.ts.

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# SQL Server. The password must match MSSQL_SA_PASSWORD in the ROOT .env (docker-compose).
# trustServerCertificate is required in dev because the container uses a self-signed cert.
DATABASE_URL="sqlserver://localhost:1433;database=qramc;user=sa;password=ChangeMe_Dev123!;encrypt=true;trustServerCertificate=true"

# Auth. Generate a real one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h

# Comma-separated list of origins allowed to call the API.
CORS_ORIGIN=http://localhost:5173

# Base URL printed into every QR label, as https://<host>/asset/<id>.
# WARNING: permanent once the first sticker is printed — a change orphans every label in the field.
PUBLIC_APP_URL=http://localhost:5173
