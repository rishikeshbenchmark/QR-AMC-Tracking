# Root .env — consumed by docker-compose only. Copy to .env and edit.
# The application's own configuration lives in server/.env (see server/.env.example).

# SQL Server SA password. Must satisfy SQL Server's policy:
# 8+ chars with upper, lower, digit and symbol — the container silently fails to start otherwise.
MSSQL_SA_PASSWORD=ChangeMe_Dev123!

# Host port to publish SQL Server on. Change if 1433 is already taken on your machine.
MSSQL_PORT=1433
